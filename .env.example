AI_DELIVERY_ENV=local
AI_DELIVERY_PROVIDER=mock
AI_DELIVERY_CONFIG=configs/settings.yaml
AI_DELIVERY_MODELS=configs/models.yaml
AI_DELIVERY_BRAND=configs/clients/demo_brand.yaml
AI_DELIVERY_OUTPUT_DIR=outputs
AI_DELIVERY_WORKSPACE_DIR=workspace/generated_app

# Snowflake runtime configuration
# Switch AI_DELIVERY_PROVIDER to snowflake when the real provider is implemented.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_HOST=
SNOWFLAKE_AUTHENTICATOR=

# Snowflake Cortex / model settings
SNOWFLAKE_CORTEX_MODEL=snowflake-arctic-instruct
SNOWFLAKE_CORTEX_REQUEST_TIMEOUT=60
SNOWFLAKE_CORTEX_USE_REST=false
